# Demo-pack environment template — copy to `.env` at the repo root and fill in.
# NEVER commit a populated `.env` (only `.env.example` is tracked; see .gitignore).
# Secrets live here, NEVER inline in `panoptes.yaml` — the config interpolates `${VAR}`.
#
# This is the demo-pack-scoped slice of the top-level `.env.example`. A real consumer
# keeps an equivalent file alongside ITS OWN pack and points the injection config at it.

# --- Consumer-pack injection (defaults to this in-repo brand-neutral demo pack) ---
# The mounted dir the Grafana provider globs `dashboards/**/dashboard.json` from.
CONSUMER_PACK_DIR=examples/demo-pack
# The pack module the MCP server imports + calls `register_tools(...)` on. In compose
# the pack dir is bind-mounted read-only at /packs/consumer, so this is the mounted
# path; for a local (non-compose) run point it at the dotted module instead.
PANOPTES_CONSUMER_PACK=/packs/consumer/pack.py

# --- Observed-env read credentials (read-only; supplied by the operator) ----------
AWS_REGION=<your-aws-region>
# A read-only AWS profile holding CloudWatch + Logs READ permissions only.
AWS_PROFILE=panoptes-dev-readonly
# Forward-compatible with the PanoptesReadRole cross-account read role. When set,
# `assume_role_arn` takes precedence over `profile`; supply the external id to match
# the trust policy's sts:ExternalId confused-deputy guard.
# PANOPTES_ASSUME_ROLE_ARN=arn:aws:iam::<acct>:role/PanoptesReadRole/dev
# PANOPTES_EXTERNAL_ID=<per-env-external-id>

# Sentry org/project slugs + a READ-ONLY / viewer-scoped API token (no project:write,
# no org:admin) — the same least-privilege discipline IAM.md applies to AWS reads.
SENTRY_ORG=<org-slug>
SENTRY_PROJECT=<project-slug>
SENTRY_TOKEN=<read-only-sentry-api-token>

# A reachable HTTP `/health` endpoint for the observed `dev` environment.
DEV_HEALTH_URL=https://<your-dev-host>/health
