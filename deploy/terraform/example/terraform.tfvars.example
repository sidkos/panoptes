# Copy to `terraform.tfvars` and fill for your deployment. NOTE: the chart's two secrets
# (the GitHub OAuth client secret + the Slack webhook) are NOT Terraform inputs — a sensitive
# TF value lands in state in plaintext. Supply them directly to the out-of-band Kubernetes
# Secrets the chart references (`panoptes-oauth2-proxy` / `panoptes-app-secrets`), not here.

home_region = "us-east-1"
hostname    = "panoptes.example.com"
image_tag   = "v0.2.0" # an IMMUTABLE tag, never :latest

# REQUIRED allowlist for the EKS public API endpoint — REPLACE with your operator IP/CIDR.
# The module has NO default here (the AWS default is 0.0.0.0/0 = the whole internet); the
# placeholder is an RFC5737 doc range that reaches nothing, so a forgotten value fails closed.
cluster_endpoint_public_access_cidrs = ["203.0.113.4/32"]

github_oauth_client_id = "Iv1.0123456789abcdef"
github_org = "your-github-org"
# github_team = "platform"             # optional finer gate

# The per-env read-roles the IRSA role may assume, IN-ACCOUNT. Empty = no grants (stage/prod
# stay disabled stubs). Light up an env by adding its PanoptesReadRole ARN here.
read_role_arns = [
  "arn:aws:iam::111122223333:role/PanoptesReadRole-dev",
]

# The single Panoptes-owned SNS alert topic the IRSA role may publish to (resource-scoped).
alert_topic_arn = "arn:aws:sns:us-east-1:111122223333:panoptes-alerts"
