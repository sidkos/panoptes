# Copy to `.env` and fill in. NEVER commit a populated .env (only .env.example is
# tracked; see .gitignore). `docker compose` reads this file automatically; the
# integration test suite does NOT (CI is hermetic — Risk R10 — and spins ephemeral
# containers with synthetic data only, no live AWS/Sentry).

# --- Consumer-pack injection (the only required value) ---------------------------
# The consumer's pack dir, bind-mounted READ-ONLY at /packs/consumer and into
# Grafana's dashboard provisioning. Defaults to the in-repo brand-neutral demo pack;
# a real consumer points this at its own repo dir. `${CONSUMER_PACK_DIR:?}` in the
# compose file fails fast if this is unset. MUST be a bind-mountable path —
# `./`-prefixed-relative or absolute (a bare `examples/demo-pack` would be read as a
# named volume by compose, not a host bind mount).
CONSUMER_PACK_DIR=./examples/demo-pack
# The mounted pack.py the MCP server loads (a FILE PATH inside the container — the
# server imports it via importlib.util.spec_from_file_location).
PANOPTES_CONSUMER_PACK=/packs/consumer/pack.py
# The mounted config the collector + MCP server read (inside the container).
PANOPTES_CONFIG=/packs/consumer/panoptes.yaml

# --- Stack infrastructure (compose-internal; safe defaults, not secrets) ---------
# Host ports the VictoriaMetrics + Grafana containers publish.
VM_HOST_PORT=8428
GRAFANA_HOST_PORT=3000
# VictoriaMetrics retention window (mirrors the store `retention:` in panoptes.yaml).
VM_RETENTION=15d

# --- Observed-env read credentials (read-only; supplied by the operator) ---------
# Needed ONLY for a real `docker compose up` against a live env — NOT for CI/tests.
AWS_REGION=<your-aws-region>
AWS_PROFILE=panoptes-dev-readonly
# or, forward-compatible with PanoptesReadRole (cross-account read role):
# PANOPTES_ASSUME_ROLE_ARN=arn:aws:iam::<acct>:role/PanoptesReadRole/dev
# PANOPTES_EXTERNAL_ID=<per-env-external-id>

SENTRY_ORG=<org-slug>
SENTRY_PROJECT=<project-slug>
# Must be a read-only/viewer-scoped token (no project:write, no org:admin) — the same
# least-privilege discipline the IAM guidance applies to PanoptesReadRole.
SENTRY_TOKEN=<read-only-sentry-api-token>

# The reference dev env's HTTP health endpoint the http-health source probes.
DEV_HEALTH_URL=https://<reference-dev>/health
