{
  "title": "Datastore",
  "uid": null,
  "tags": ["panoptes", "core", "datastore", "cloudwatch"],
  "timezone": "utc",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "query",
        "label": "Environment",
        "datasource": "VictoriaMetrics",
        "query": "label_values(panoptes_log_error_rate, env)",
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Log error rate by log group",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "VictoriaMetrics",
      "targets": [
        {
          "refId": "A",
          "expr": "max by (log_group) (panoptes_log_error_rate{env=~\"$env\"})",
          "legendFormat": "{{log_group}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Peak log error rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": "VictoriaMetrics",
      "targets": [
        {
          "refId": "A",
          "expr": "max (panoptes_log_error_rate{env=~\"$env\"})",
          "legendFormat": "peak"
        }
      ]
    },
    {
      "id": 3,
      "title": "Datastore service spend",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": "VictoriaMetrics",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (panoptes_cost_spend{env=~\"$env\"})",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ]
}
