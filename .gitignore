# IDE / editor
.idea/
.vscode/
*.swp

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
.mypy_cache/
.pytest_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# Coverage
.coverage
.coverage.*
htmlcov/

# Terraform — provider plugins + local state/plan artifacts are generated by
# `init`/`plan` and must never be committed. The provider lock file is intentionally
# NOT committed for the Phase-0 skeleton module (no pinned providers are consumed yet);
# Phase 6 may add a committed `.terraform.lock.hcl` once the real providers land.
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
# A filled `terraform.tfvars` carries real secrets (the GitHub OAuth secret, the Slack
# webhook) and must NEVER be committed; the tracked `*.tfvars.example` placeholder stays
# tracked (the negation re-includes it after the broad `*.tfvars` ignore).
*.tfvars
!*.tfvars.example

# Environment / secrets (consumer packs supply their own .env; never commit it)
.env
.env.*
!.env.example

# OS
.DS_Store
